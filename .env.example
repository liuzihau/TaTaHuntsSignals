# Demo mode works without API keys.
APP_MODE=demo
DEFAULT_TICKER=NVDA
# Get from https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...
# Optional override (defaults to a current Sonnet model)
ANTHROPIC_MODEL=claude-sonnet-4-0

# PostgreSQL (RAG pipeline)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tatahunts_user
POSTGRES_PASSWORD=tatahunts_password
POSTGRES_DB=tatahunts_rag

# Milvus (vector DB)
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Embedding
EMBEDDING_MODEL=BAAI/bge-large-en
EMBEDDING_DEVICE=cuda
EMBEDDING_BATCH_SIZE=32
